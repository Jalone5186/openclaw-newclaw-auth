{
  "name": "openclaw-newclaw-auth",
  "version": "0.1.2",
  "description": "NewClaw AI API integration — all models through newclaw.ai",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "openclaw.plugin.json"],
